# Database Connection
# format: mysql+pymysql://username:password@host:port/database_name
# For XAMPP MySQL, the default user is root with no password, running on port 3306
DATABASE_URL=mysql+pymysql://root:@localhost:3306/sportcircle

# JWT Security
JWT_SECRET=super_secret_sportcircle_jwt_key_2026

# Settings
PROJECT_NAME=SportCircle
PROJECT_VERSION=1.0.0
